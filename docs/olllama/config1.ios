router bgp 2020
 bgp router-id 192.168.20.12
 neighbor 192.168.20.9 remote-as 2020
  update-source Loopback0
  next-hop-self
  route-reflector-client
 !
 neighbor 192.168.20.10 remote-as 2020
  update-source Loopback0
  next-hop-self
  route-reflector-client
